<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.andrelmv.kotbox</id>
    <name>Kotlin Toolbox</name>
    <vendor email="andrelmv@gmail.com" url="https://github.com/andrelmv/kotbox">André Monteiro</vendor>

    <!-- Product and plugin compatibility requirements -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">

        <applicationService serviceImplementation="com.github.andrelmv.kotbox.inlay.config.InlayStringInterpolationSettings"/>

        <toolWindow factoryClass="com.github.andrelmv.kotbox.toolwindow.ui.window.MainWindowFactory" id="Kotlin ToolBox"
                    icon="/icons/toolWindow.svg" anchor="right" secondary="false"/>

        <codeInsight.inlayProvider
                implementationClass="com.github.andrelmv.kotbox.inlay.config.InlayStringInterpolationProvider"
                language="kotlin"/>

        <intentionAction>
            <language>kotlin</language>
            <className>com.github.andrelmv.kotbox.wrap.WrapWithCoroutineIntention</className>
            <category>Kotlin Toolbox</category>
        </intentionAction>

        <intentionAction>
            <language>kotlin</language>
            <className>com.github.andrelmv.kotbox.dslbuilder.DslBuilderIntention</className>
            <category>Kotlin Toolbox</category>
        </intentionAction>

      <intentionAction>
        <language>kotlin</language>
        <className>com.github.andrelmv.kotbox.inlay.CopyInterpolatedValueIntention</className>
        <category>Kotlin Toolbox</category>
      </intentionAction>

    </extensions>


    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <actions>

        <!-- Grupo de wrap — adicionado no menu de contexto do editor -->
        <group id="KotlinToolbox.WrapGroup"
               text="Wrap with coroutine"
               description="Wrap o código selecionado com um coroutine builder"
               popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </group>

        <!-- Action: wrap com async { } -->
        <action id="KotlinToolbox.WrapAsync"
                class="com.github.andrelmv.kotbox.wrap.wrappers.WrapAsyncAction"
                text="Wrap with async { }"
                description="Envolve o código selecionado com async { }">
            <add-to-group group-id="KotlinToolbox.WrapGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl alt meta Y"/>
        </action>

        <!-- Action: wrap com coroutineScope { } -->
        <action id="KotlinToolbox.WrapCoroutineScope"
                class="com.github.andrelmv.kotbox.wrap.wrappers.WrapCoroutineScopeAction"
                text="Wrap with coroutineScope { }"
                description="Envolve o código selecionado com coroutineScope { }">
            <add-to-group group-id="KotlinToolbox.WrapGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl alt meta O"/>
        </action>

        <!-- Action: wrap com launch { } -->
        <action id="KotlinToolbox.WrapLaunch"
                class="com.github.andrelmv.kotbox.wrap.wrappers.WrapLaunchAction"
                text="Wrap with launch { }"
                description="Envolve o código selecionado com launch { }">
            <add-to-group group-id="KotlinToolbox.WrapGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl alt meta J"/>
        </action>

        <!-- Action: wrap com withContext(Dispatchers.IO) { } -->
        <action id="KotlinToolbox.WrapWithContext"
                class="com.github.andrelmv.kotbox.wrap.wrappers.WrapWithContextAction"
                text="Wrap with withContext(Dispatchers.IO) { }"
                description="Envolve o código selecionado com withContext(Dispatchers.IO) { }">
            <add-to-group group-id="KotlinToolbox.WrapGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl alt meta W"/>
        </action>

        <!-- Action: wrap com supervisorScope { } -->
        <action id="KotlinToolbox.WrapSupervisorScope"
                class="com.github.andrelmv.kotbox.wrap.wrappers.WrapSupervisorScopeAction"
                text="Wrap with supervisorScope { }"
                description="Envolve o código selecionado com supervisorScope { }">
            <add-to-group group-id="KotlinToolbox.WrapGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl alt meta S"/>
        </action>

        <!-- Action: wrap com runBlocking { } -->
        <action id="KotlinToolbox.WrapRunBlocking"
                class="com.github.andrelmv.kotbox.wrap.wrappers.WrapRunBlockingAction"
                text="Wrap with runBlocking { }"
                description="Envolve o código selecionado com runBlocking { }">
            <add-to-group group-id="KotlinToolbox.WrapGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl alt meta B"/>
        </action>

        <!-- Action: wrap com withTimeout(timeMillis) { } -->
        <action id="KotlinToolbox.WrapWithTimeout"
                class="com.github.andrelmv.kotbox.wrap.wrappers.WrapWithTimeoutAction"
                text="Wrap with withTimeout(timeMillis) { }"
                description="Envolve o código selecionado com withTimeout(timeMillis) { }">
            <add-to-group group-id="KotlinToolbox.WrapGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl alt meta T"/>
        </action>

        <!-- Action: Generate DSL Builder -->
        <action id="KotlinToolbox.GenerateDslBuilder"
                class="com.github.andrelmv.kotbox.dslbuilder.DslBuilderAction"
                text="DSL Builder..."
                description="Generate a type-safe DSL builder for this data class">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift D"/>
        </action>

    </actions>

</idea-plugin>
